# Copy this file to `.env` and fill in real values.
# `.env` is gitignored and must NEVER be committed.

# Anthropic API key — used for generating coaching reports.
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Model used for the coaching report (Sonnet 4.6 is a good default).
COACH_MODEL=claude-sonnet-4-6

# Telegram notifications (optional). Set the bot token to get done/failed pings.
# CHAT_ID auto-detects from recent messages if left blank (message the bot once).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Host/port the web app binds to.
# 0.0.0.0 makes it reachable over your Tailscale network (e.g. from your phone).
HOST=0.0.0.0
PORT=8042

# If served under a subpath via `tailscale serve` (e.g. /lucid), set it here so
# all generated links are prefixed. Leave blank when serving at the root.
URL_PREFIX=

# Public https base URL (your Tailscale host) — used only to build clickable
# links inside Telegram pings. Leave blank to omit links.
PUBLIC_URL=

# Where private data (db, audio, transcripts, reports) is stored on this machine.
DATA_DIR=data
